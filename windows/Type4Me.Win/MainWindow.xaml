<Window x:Class="Type4Me.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Type4Me Windows" Height="780" Width="1080" MinWidth="920" MinHeight="680"
        Background="#F5F7FA" FontFamily="Segoe UI, Microsoft YaHei UI" FontSize="13">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DDE4EC" />
        <SolidColorBrush x:Key="TextBrushMain" Color="#17212B" />
        <SolidColorBrush x:Key="TextBrushMuted" Color="#637083" />
        <SolidColorBrush x:Key="AccentBrush" Color="#197A82" />
        <SolidColorBrush x:Key="AccentBrushDark" Color="#12626A" />

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>

        <Style x:Key="SectionDescriptionStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource TextBrushMuted}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style x:Key="SectionCardStyle" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="BorderBrush" Value="#B8C5D2" />
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="#FFFFFF" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,4" />
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#B8C5D2" />
        </Style>

        <Style TargetType="{x:Type PasswordBox}">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="BorderBrush" Value="#B8C5D2" />
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="RowHeight" Value="30" />
            <Setter Property="ColumnHeaderHeight" Value="32" />
            <Setter Property="HorizontalGridLinesBrush" Value="#E5ECF2" />
            <Setter Property="VerticalGridLinesBrush" Value="#E5ECF2" />
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Background" Value="#F4F7FA" />
            <Setter Property="Foreground" Value="{StaticResource TextBrushMain}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderBrush" Value="#DDE4EC" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="BorderBrush" Value="#EEF2F6" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabControl}">
                        <Grid KeyboardNavigation.TabNavigation="Local">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="164" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TabPanel Grid.Column="0"
                                      IsItemsHost="True"
                                      KeyboardNavigation.TabIndex="1"
                                      Background="Transparent"
                                      Margin="0,0,12,0" />
                            <Border Grid.Column="1">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TabItem}">
            <Setter Property="Width" Value="150" />
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Foreground" Value="{StaticResource TextBrushMuted}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="NavItem"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="#FFFFFF"
                                BorderBrush="{StaticResource BorderBrushSoft}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              TextBlock.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="NavItem" Property="Background" Value="#E9F4F3" />
                                <Setter TargetName="NavItem" Property="BorderBrush" Value="#9BCDC7" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrushDark}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="NavItem" Property="BorderBrush" Value="#9BCDC7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel Margin="22">
        <Border DockPanel.Dock="Top" Background="#E9F4F3" BorderBrush="#C8E2DF" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource AccentBrush}" Margin="0,0,14,0">
                    <TextBlock Text="T" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="Type4Me Windows" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="语音识别、文本处理、快捷键和历史记录集中管理" Foreground="{StaticResource TextBrushMuted}" Margin="0,3,0,0" />
                </StackPanel>
                <Border Grid.Column="2" Background="#FFFFFF" BorderBrush="#C8E2DF" BorderThickness="1" CornerRadius="18" Padding="12,7" VerticalAlignment="Center">
                    <TextBlock x:Name="StatusText" Text="就绪。默认快捷键：Ctrl+Alt+空格 快速输入；Ctrl+Shift+空格 智能润色。" TextWrapping="Wrap" MaxWidth="330" />
                </Border>
            </Grid>
        </Border>

        <TabControl TabStripPlacement="Left">
            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="820" Margin="10,0,0,0">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="语音识别" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="选择语音服务，填写凭据后可以先测试连通性。这里的设置会影响所有输入模式。" Style="{StaticResource SectionDescriptionStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="AsrProviderCombo" SelectionChanged="AsrProviderCombo_OnSelectionChanged" />
                                    <Button x:Name="TestAsrButton" Grid.Column="1" Content="测试语音模型" Click="TestAsrButton_OnClick" Width="132" Margin="10,0,0,0" />
                                </Grid>
                                <StackPanel x:Name="AsrFieldsPanel" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="文本处理" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="用于智能润色、翻译和自定义提示词。快速输入模式不会强制调用文本模型。" Style="{StaticResource SectionDescriptionStyle}" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="LlmProviderCombo" SelectionChanged="LlmProviderCombo_OnSelectionChanged" />
                                    <Button x:Name="TestLlmButton" Grid.Column="1" Content="测试文本模型" Click="TestLlmButton_OnClick" Width="132" Margin="10,0,0,0" />
                                </Grid>
                                <StackPanel x:Name="LlmFieldsPanel" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="输出方式" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="控制识别文本的标点处理。自动输入会继续使用当前输入框焦点。" Style="{StaticResource SectionDescriptionStyle}" />
                                <ComboBox x:Name="PunctuationModeCombo" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,20">
                            <Button Content="保存设置" Click="SaveButton_OnClick" Width="128" Height="38" Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="快捷键">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel MaxWidth="860" Margin="10,0,0,0">
                        <Border Style="{StaticResource SectionCardStyle}">
                            <StackPanel>
                                <TextBlock Text="输入模式快捷键" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="点击快捷键输入框后直接按新的组合键。单个 Ctrl、Alt、Shift、Win 也可以作为按住说话键。" Style="{StaticResource SectionDescriptionStyle}" />
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="260" />
                                        <ColumnDefinition Width="220" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="模式" Foreground="{StaticResource TextBrushMuted}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="1" Text="快捷键" Foreground="{StaticResource TextBrushMuted}" FontWeight="SemiBold" />
                                    <TextBlock Grid.Column="2" Text="触发方式" Foreground="{StaticResource TextBrushMuted}" FontWeight="SemiBold" />
                                </Grid>
                                <StackPanel x:Name="HotkeysPanel" />
                            </StackPanel>
                        </Border>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="保存快捷键" Click="SaveHotkeysButton_OnClick" Width="128" Height="38" Style="{StaticResource PrimaryButtonStyle}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="历史">
                <DockPanel Margin="10,0,0,0">
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="识别历史" Style="{StaticResource SectionTitleStyle}" />
                                <TextBlock Text="最近 200 条记录，包含原始识别、处理后文本、模式和状态。" Style="{StaticResource SectionDescriptionStyle}" Margin="0,0,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button Content="刷新" Click="RefreshHistoryButton_OnClick" Width="92" Margin="0,0,8,0" />
                                <Button Content="导出 CSV" Click="ExportCsvButton_OnClick" Width="108" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="8" Padding="0">
                        <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  RowHeaderWidth="0" AlternatingRowBackground="#F7FAFC"
                                  BorderThickness="0" CanUserAddRows="False" CanUserDeleteRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding CreatedAt}" Width="170" />
                                <DataGridTextColumn Header="模式" Binding="{Binding ProcessingMode}" Width="110" />
                                <DataGridTextColumn Header="最终文本" Binding="{Binding FinalText}" Width="*" />
                                <DataGridTextColumn Header="原始识别" Binding="{Binding RawText}" Width="*" />
                                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90" />
                                <DataGridTextColumn Header="服务" Binding="{Binding ASRProvider}" Width="90" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
